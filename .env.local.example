YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
JWT_SECRET=change-me-to-a-long-random-string

# Yandex ID OAuth (sign-in)
# Redirect URI MUST be: https://mishkaznaet.ru/api/auth/yandex/callback
