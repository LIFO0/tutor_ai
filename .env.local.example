YANDEX_GPT_API_KEY=
YANDEX_FOLDER_ID=
JWT_SECRET=change-me-to-a-long-random-string

# Yandex ID OAuth (sign-in)
# Redirect URI MUST be: https://mishkaznaet.ru/api/auth/yandex/callback
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=https://mishkaznaet.ru/api/auth/yandex/callback

# Daily usage limits (Europe/Moscow reset at midnight)
# USAGE_QUOTA_DISABLED=1
USAGE_FREE_CHAT_PER_DAY=16
USAGE_FREE_TASK_GEN_PER_DAY=4
USAGE_FREE_TASK_CHECK_PER_DAY=6
USAGE_FREE_CHAT_SESSIONS_PER_DAY=10
USAGE_BURST_CHAT_PER_MIN=8
USAGE_PLUS_CHAT_PER_DAY=50
USAGE_PLUS_TASK_GEN_PER_DAY=12
USAGE_PLUS_TASK_CHECK_PER_DAY=24
USAGE_PLUS_CHAT_SESSIONS_PER_DAY=30
USAGE_PLUS_BURST_CHAT_PER_MIN=16

# Admin bypass (comma-separated emails from users.email — works with Yandex OAuth too)
# USAGE_QUOTA_EXEMPT_EMAILS=you@yandex.ru,cofounder@example.com
# USAGE_QUOTA_EXEMPT_USER_IDS=1,2

