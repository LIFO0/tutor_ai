# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.npm/
/.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.turbo/
/.swc/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# user uploads (created at runtime)
/public/uploads/avatars/

# sqlite (runtime DB lives outside the repo; see src/lib/db/index.ts)
database.db
database.db-*
*.sqlite
*.sqlite3
*.db
*.db-*
*.db-journal
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
/.data/

# repository root hygiene (canonical assets live in public/)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# local-only archive drops (tracked _archive/ stays in git)
/_archive/local-artifacts/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors / os
.idea/
.vscode/
Thumbs.db
*.stackdump
