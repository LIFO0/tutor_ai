{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "doctor:native": "node scripts/ensure-native-deps.mjs",
    "predev": "npm run doctor:native",
    "dev": "next dev --turbopack",
    "predev:turbo": "npm run doctor:native",
    "dev:turbo": "next dev --turbopack",
    "predev:webpack": "npm run doctor:native",
    "dev:webpack": "next dev --webpack --disable-source-maps",
    "predev:mem": "npm run doctor:native",
    "dev:mem": "cmd /c \"set \\\"NODE_OPTIONS=--heapsnapshot-near-heap-limit=3 --trace-gc\\\" && next dev --turbopack\"",
    "predev:inspect": "npm run doctor:native",
    "dev:inspect": "next dev --turbopack --inspect 9229",
    "prebuild": "npm run doctor:native",
    "build": "next build",
    "prestart": "npm run doctor:native",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "migrate:normalize-messages": "tsx scripts/migrate-normalize-messages.ts",
    "predb:push": "npm run doctor:native",
    "db:push": "drizzle-kit push",
    "predb:studio": "npm run doctor:native",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "mathlive": "^0.109.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
